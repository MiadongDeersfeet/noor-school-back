<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.noorschool.terms.mapper.TermsMapper">

    <resultMap id="TermsResultMap" type="com.noorschool.terms.model.dto.TermsDTO">
        <id property="termsId" column="TERMS_ID"/>
        <result property="termsType" column="TERMS_TYPE"/>
        <result property="version" column="VERSION"/>
        <result property="titleAr" column="TITLE_AR"/>
        <result property="contentAr" column="CONTENT_AR"/>
        <result property="isRequired" column="IS_REQUIRED"/>
    </resultMap>

    <select id="selectActiveTerms" resultMap="TermsResultMap">
        SELECT TERMS_ID, TERMS_TYPE, VERSION, TITLE_AR, CONTENT_AR, IS_REQUIRED
        FROM TB_TERMS
        WHERE IS_ACTIVE = 'Y'
        ORDER BY TERMS_ID
    </select>

    <insert id="insertAgreement">
        INSERT INTO TB_TERMS_AGREEMENT (MEMBER_ID, TERMS_ID, IS_AGREED, AGREED_AT)
        VALUES (#{memberId}, #{termsId}, #{isAgreed}, SYSDATE)
    </insert>

</mapper>
