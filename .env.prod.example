# Azure App Service - Application settings template
# Add these as Environment variables in Azure App Service.

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Oracle DB (OCI)
DB_URL=jdbc:oracle:thin:@//YOUR_OCI_DB_HOST:1522/YOUR_SERVICE_NAME
DB_USERNAME=YOUR_APP_DB_USERNAME
DB_PASSWORD=YOUR_APP_DB_PASSWORD

# OAuth2
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# JWT (at least 32 chars)
JWT_SECRET=CHANGE_THIS_TO_LONG_RANDOM_SECRET

# App auth/cookie
AUTH_ALLOWED_ORIGINS=https://YOUR_FRONTEND_DOMAIN
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=None
AUTH_COOKIE_DOMAIN=YOUR_DOMAIN_OR_EMPTY

# Redirect URIs
OAUTH2_SUCCESS_REDIRECT_URI=https://YOUR_FRONTEND_DOMAIN/auth/callback
OAUTH2_FAILURE_REDIRECT_URI=https://YOUR_FRONTEND_DOMAIN/auth/callback

# Azure Speech
AZURE_SPEECH_KEY=YOUR_AZURE_SPEECH_KEY
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE_NAME=ko-KR-SunHiNeural
AZURE_SPEECH_OUTPUT_FORMAT=audio-16khz-32kbitrate-mono-mp3

# Audio file path/url
AUDIO_DIR=uploads/audio/words
AUDIO_URL_PREFIX=/audio/words
